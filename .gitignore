# Node dependencies
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Environment files — never commit secrets
.env
.env.local
.env.production
.env.development
.env.development.local
.env.test.local
.env.production.local
server/.env
client/.env
client/.env.local
client/.env.production

# Allow example/template files (no real secrets)
!.env.example
!server/.env.example
!client/.env.example

# Server Uploads
server/uploads/*
!server/uploads/.gitkeep

# Production builds
client/dist/
client/build/

