# ==========================================
# InventoryFlow Server — Environment Template
# Copy this file to .env and fill in values
# ==========================================

PORT=5000

# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/digital?appName=Cluster0

# JWT Secrets — use a long random string in production
JWT_SECRET=change_this_to_a_long_random_secret
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d
JWT_REMEMBER_EXPIRY=30d

# Allowed frontend origins (comma-separated, no spaces)
# LOCAL:      http://localhost:5173
# PRODUCTION: https://your-app.vercel.app
CLIENT_URL=http://localhost:5173
CLIENT_URLS=http://localhost:5173,https://your-app.vercel.app

# Set to 'production' on Render
NODE_ENV=development
